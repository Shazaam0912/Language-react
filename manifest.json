{
  "manifest_version": 3,
  "name": "YouTube Dual Subtitles",
  "version": "3.1.0",
  "description": "Add DUAL SUBTITLES with Romaji to YouTube videos",
  "author": "Jim Chen",
  "homepage_url": "https://jimchen.me",
  "permissions": [
    "storage",
    "tabs",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://jisho.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "YouTube Dual Subtitles Settings",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": [
        "lib/kuromoji.js",
        "jlpt-data.js",
        "content.js"
      ],
      "css": [
        "subtitle-overlay.css",
        "sidebar.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js",
        "lib/dict/*"
      ],
      "matches": [
        "https://*.youtube.com/*"
      ]
    }
  ]
}